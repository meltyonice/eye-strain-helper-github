{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "meltyonice.eye-strain-helper",
	"name": "Eye Strain Helper",
	"version": "v1.0.0",
	"developer": "MeltyOnIce",
	"links": {
		"source": "https://codeberg.org/meltyonice/geode-eyestrain"
	},
	"settings": {
		"enabled": {
			"type": "bool",
			"name": "Enable Eye Strain Helper",
			"default": true
		},
		"breakDuration": {
			"type": "int",
			"name": "break duration (seconds)",
			"default": 30
		},
		"betweenBreaks": {
			"type": "int",
			"name": "time between breaks (minutes)",
			"default": 20
		},
		"shouldIntegrateEyeSaver": {
			"type": "bool",
			"name": "Eye Saver Integration",
			"default": false,
			"description": "Enables support for integration with the desktop program Safe Eyes. Requires the Safe Eyes plugin found in this mod 's git repository in order to work.",
			"requires-restart": true,
			"platforms": ["win"]
		},
		"debugTitle": {
			"type": "title",
            "name": "Debugging"
		},
		"timingAlertEnabled": {
			"type": "bool",
			"name": "enable timing info alert",
			"default": false
		},
		"breakEveryAttempt": {
			"type": "bool",
			"name": "strain break on every attempt",
			"default": false
		},
		"fiveSecondInterval": {
			"type": "bool",
			"name": "five second break interval in editor",
			"default": false
		}
	},
	"description": "A mod that helps prevent eye strain without interrupting attempts like external software would.",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	}
}
